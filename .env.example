# ============================================================
# CDA BET — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# ============================================================

# URL de connexion PostgreSQL
# Local Docker : postgres://user_footix:password_footix@db:5432/footix_score
# Railway      : fournie automatiquement dans le dashboard Railway
DATABASE_URL=postgres://user_footix:password_footix@db:5432/footix_score

# Clé secrète JWT — change-la en production (chaîne aléatoire longue)
JWT_SECRET=footix_jwt_secret_2026

# Environnement
NODE_ENV=production

# Port d'écoute de l'API (Railway injecte PORT automatiquement)
PORT=8000
